<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SkyForce.Views.MainWindow"
        Title="SkyForce" Width="600" Height="900"
        WindowStartupLocation="CenterScreen" CanResize="False"
        Focusable="True" KeyDown="OnKeyDown" KeyUp="OnKeyUp">

    <Canvas Name="MainCanvas" Background="Black">
        <Image Name="MainBackground" Source="avares://SkyForce/Assets/Backgrounds/fundo1.png" 
               Width="600" Height="2000" Stretch="Fill" ZIndex="0"/>

        <Canvas Name="PlayArea" Width="600" Height="900" IsVisible="False" ZIndex="1">
            <Canvas Name="ProjectilesLayer" Width="600" Height="900" />
            <Image Name="PlayerShip" Width="64" Height="64" ZIndex="10"/>

            <StackPanel Name="ScoreContainer" 
                        Orientation="Horizontal" 
                        Canvas.Right="20" 
                        Canvas.Top="20" 
                        ZIndex="20">
                <StackPanel.RenderTransform>
                    <ScaleTransform ScaleX="1.0" ScaleY="1.0" />
                </StackPanel.RenderTransform>
            </StackPanel>
        </Canvas>

        <StackPanel Name="TitleScreen" Width="600" Height="900" IsVisible="True" ZIndex="5">
            <Image Source="avares://SkyForce/Assets/Backgrounds/SkyForceLogo.png" Width="450" Margin="0,150,0,50"/>
            <Image Name="ImgPressEnter" Source="avares://SkyForce/Assets/Backgrounds/PressEnterLogo.png" Width="300" Margin="0,100,0,0"/>
        </StackPanel>

        <StackPanel Name="CharacterSelectScreen" Width="600" Height="900" IsVisible="False" 
                    ZIndex="6" Background="#EE000000">
            <Image Source="avares://SkyForce/Assets/Backgrounds/selectpilot.png" 
                   Width="400" Margin="0,100,0,30" HorizontalAlignment="Center"/>
            <Border BorderBrush="Cyan" BorderThickness="2" CornerRadius="10" 
                    Width="220" Height="220" HorizontalAlignment="Center" Background="#3300FFFF">
                <Image Name="SelectedShipPreview" Width="200" Height="200" Stretch="Uniform"/>
            </Border>
            <TextBlock Name="TxtPilotName" FontSize="32" Foreground="Yellow" 
                       HorizontalAlignment="Center" Margin="0,20,0,10" FontWeight="Bold"/>
            <TextBlock Text="&lt; SETAS PARA ESCOLHER | ENTER PARA CONFIRMAR >" 
                       FontSize="16" Foreground="White" HorizontalAlignment="Center" Margin="0,50,0,0"/>
        </StackPanel>

        <StackPanel Name="GameOverScreen" Width="600" Height="900" IsVisible="False" ZIndex="7" Background="Black">
            <Image Source="avares://SkyForce/Assets/Backgrounds/gameover.png" Width="500" Margin="0,200,0,20" Stretch="Uniform"/>
            <Image Name="ImgPressEnterRestart" Source="avares://SkyForce/Assets/Backgrounds/PressEnterLogo.png" Width="280" HorizontalAlignment="Center"/>
            <TextBlock Text="Pressione ESC para o Menu" FontSize="18" Foreground="Gray" HorizontalAlignment="Center" Margin="0,40,0,0"/>
        </StackPanel>

        <StackPanel Name="VictoryScreen" Width="600" Height="900" IsVisible="False" ZIndex="8" Background="Black">
            <Image Source="avares://SkyForce/Assets/Backgrounds/youwin.png" Width="500" Margin="0,180,0,20" Stretch="Uniform"/>
            <Image Name="ImgPressEnterVictory" Source="avares://SkyForce/Assets/Backgrounds/PressEnterLogo.png" Width="280" HorizontalAlignment="Center"/>
            <TextBlock Text="MISSÃO CUMPRIDA! Pressione ESC para sair" FontSize="18" Foreground="Cyan" HorizontalAlignment="Center" Margin="0,40,0,0"/>
        </StackPanel>
        
    </Canvas>
</Window>